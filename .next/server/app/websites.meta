{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/websites/layout,_N_T_/websites/page,_N_T_/websites"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/websites/__PAGE__",
    "/websites",
    "/_index",
    "/_head"
  ]
}